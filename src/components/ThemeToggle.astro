<button
  type="button"
  class="theme-toggle mt-4 ml-2"
  data-theme-toggle
  aria-label="Passa al tema scuro"
>
  <svg class="theme-icon icon-sun" viewBox="0 0 24 24" aria-hidden="true">
    <circle cx="12" cy="12" r="4"></circle>
    <path d="M12 2v2"></path>
    <path d="M12 20v2"></path>
    <path d="M4.93 4.93l1.41 1.41"></path>
    <path d="M17.66 17.66l1.41 1.41"></path>
    <path d="M2 12h2"></path>
    <path d="M20 12h2"></path>
    <path d="M4.93 19.07l1.41-1.41"></path>
    <path d="M17.66 6.34l1.41-1.41"></path>
  </svg>
  <svg class="theme-icon icon-moon" viewBox="0 0 24 24" aria-hidden="true">
    <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"></path>
  </svg>
</button>

<script is:inline>
  (() => {
    const key = 'theme-preference';
    const options = ['light', 'dark'];

    const button = document.querySelector('[data-theme-toggle]');
    if (!button) return;

    const root = document.documentElement;

    const getStoredTheme = () => {
      const value = localStorage.getItem(key);
      if (value === 'light' || value === 'dark') {
        return value;
      }
      return null;
    };

    const applyTheme = (theme, persist = false) => {
      const resolved = theme === 'dark' ? 'dark' : 'light';

      if (persist) {
        localStorage.setItem(key, resolved);
      }

      root.classList.remove('light', 'dark');
      root.classList.add(resolved);
      root.style.colorScheme = resolved;

      button.dataset.theme = resolved;
      button.setAttribute(
        'aria-label',
        resolved === 'dark' ? 'Passa al tema chiaro' : 'Passa al tema scuro'
      );
    }

    const classTheme = root.classList.contains('dark') ? 'dark' : 'light';
    const storedTheme = getStoredTheme();
    applyTheme(storedTheme ?? classTheme, false);

    button.addEventListener('click', () => {
      const current = root.classList.contains('dark') ? 'dark' : 'light';
      const index = options.indexOf(current);
      const next = options[(index + 1) % options.length];
      applyTheme(next, true);
    });
  })();
</script>
